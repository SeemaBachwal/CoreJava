class Solution {
    public int maxProfit(int[] prices) {

        int min = prices[0], profit = 0, max = 0;

        if (prices.length == 0)
            return 0;

        for (int i = 0; i < prices.length; i++) {

            if (prices[i] < min) {
                min = prices[i];
            }

            profit = prices[i] - min;

            if (profit > max) {
                max = profit;
            }
        }

        return max;

    }
}
